        "# Deployment phase using pickle library for save and load the model\n",
        "\n",
        "import pickle\n",
        "loaded_model = pickle.load(open(\"finalize_model_linear.sav\", \"rb\"))\n",
        "salary = int(input(\"Enter Experince: \"))\n",
        "result = loaded_model.predict([[salary]])\n",
        "print(\"The Predicted salary is:\",result)"
